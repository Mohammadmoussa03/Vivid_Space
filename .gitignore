# --- Secrets: never commit ---
.env
.env.*
!.env.example
!.env.production.template
*.pem
*.key

# --- Python ---
venv/
__pycache__/
*.pyc
db.sqlite3
*.log
backend/staticfiles/
backend/media/

# --- Node / frontend build ---
node_modules/
frontend/dist/
frontend/.vite/

# --- Terraform (state holds secrets) ---
terraform/.terraform/
terraform/*.tfstate
terraform/*.tfstate.*
terraform/*.tfvars
!terraform/*.tfvars.example
terraform/.terraform.lock.hcl

# --- OS / editor ---
.DS_Store
.idea/
.vscode/

# temp admin password (local only)
.admin_pw.tmp
