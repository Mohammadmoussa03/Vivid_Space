# Copy to .env and fill in. Never commit the real .env.
# Generate a strong key, e.g.:
#   python -c "from django.core.management.utils import get_random_secret_key as k; print(k())"
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
# DEBUG now DEFAULTS TO FALSE. Keep True for local dev; MUST be False in prod
# (with a real DJANGO_SECRET_KEY, or the app refuses to start).
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- Auth cookies / CSRF / security -------------------------------------------
# JWTs are delivered as httpOnly cookies (never in JS-readable storage). These
# have safe defaults; override only if you know you need to.
# AUTH_COOKIE_SECURE defaults to (not DEBUG); force it on/off here if needed.
# AUTH_COOKIE_SECURE=True
# AUTH_COOKIE_SAMESITE=Lax
# Set if the frontend is served from a different subdomain than the API.
# AUTH_COOKIE_DOMAIN=.vividspace.co
# Origins allowed to submit CSRF-protected (cookie-authenticated) requests.
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://extinct-symmetrical-jayce.ngrok-free.dev
# Redirect http->https in production (default True when DEBUG is off).
# SECURE_SSL_REDIRECT=True
# Per-endpoint rate limits (DRF throttle rates). Defaults shown.
# THROTTLE_LOGIN=10/min                 # per IP
# THROTTLE_LOGIN_ACCOUNT=20/hour        # per account (brute-force lockout)
# THROTTLE_REGISTER=5/min
# THROTTLE_PASSWORD_RESET=5/min
# Shared cache for throttling/lockout — REQUIRED in multi-worker production so
# limits are enforced globally (LocMem is per-process). Leave blank for dev.
# REDIS_URL=redis://127.0.0.1:6379/1
# Override the Content-Security-Policy header if your static host serves its own.
# CONTENT_SECURITY_POLICY=default-src 'self'; ...
# The venue's local timezone — drives booking availability, "now" for past-slot
# filtering, and business hours. Defaults to Asia/Beirut. Use a tz database name.
# DJANGO_TIME_ZONE=Asia/Beirut

# PostgreSQL
POSTGRES_DB=vivid_space
POSTGRES_USER=vivid
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Frontend origins allowed to call the API (Vite dev server).
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://extinct-symmetrical-jayce.ngrok-free.dev
# Public site origin used to build links inside emails (e.g. password reset).
FRONTEND_URL=http://localhost:5173

# Email. Leave EMAIL_HOST_USER blank to print emails to the server console
# (development). Fill in the SMTP settings below and delivery switches to real
# email automatically — no need to set EMAIL_BACKEND by hand.
#
# Example (Gmail app password): EMAIL_HOST=smtp.gmail.com EMAIL_PORT=587 EMAIL_USE_TLS=True
# Example (SendGrid):          EMAIL_HOST=smtp.sendgrid.net EMAIL_HOST_USER=apikey
# Example (Mailgun):           EMAIL_HOST=smtp.mailgun.org EMAIL_PORT=587 EMAIL_USE_TLS=True
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=Vivid Space <no-reply@vividspace.co>
# Recipient for owner/admin notifications (overridden by Admin → Settings if set).
OWNER_EMAIL=mhmadmoussa05@gmail.com
# Force a specific backend if you ever need to (usually leave unset):
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
