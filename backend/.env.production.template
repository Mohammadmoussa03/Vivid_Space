# ==============================================================================
# Vivid Space — PRODUCTION environment template
# ------------------------------------------------------------------------------
# 1. Copy this to your server as `.env` (or load it into your host's secret store).
# 2. Replace every <PLACEHOLDER> and every "your-domain.com" with real values.
# 3. NEVER commit the filled-in file. Keep secrets out of git.
# ==============================================================================

# --- Core --------------------------------------------------------------------
# Freshly generated for you. Regenerate anytime with:
#   python -c "from django.core.management.utils import get_random_secret_key as k; print(k())"
DJANGO_SECRET_KEY=rj7tke3jwsir)8vcmzdxq^s17w9gi)^2&_f=jw#$-h097vcd*!

# MUST be False in production. Turns on HTTPS redirect, HSTS, secure cookies,
# and hides error pages. The app refuses to boot in prod with a dev secret key.
DJANGO_DEBUG=False

# Comma-separated hostnames that serve this app. No scheme, no port.
DJANGO_ALLOWED_HOSTS=your-domain.com,www.your-domain.com

# --- Auth cookies / CSRF / security ------------------------------------------
# Origins allowed to submit cookie-authenticated (CSRF-protected) requests.
# Full scheme + host, https only in prod.
CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# If the SPA is served from a different subdomain than the API, scope the cookie
# to the shared parent domain so the browser sends it to both:
# AUTH_COOKIE_DOMAIN=.your-domain.com

# These have safe prod defaults (Secure on when DEBUG is off); override only if needed.
# AUTH_COOKIE_SECURE=True
# AUTH_COOKIE_SAMESITE=Lax
# SECURE_SSL_REDIRECT=True

# --- Rate limiting (REQUIRED for multi-worker prod) --------------------------
# Without a shared cache, throttling is per-process and brute-force lockout is
# effectively bypassable. Point at your Redis instance.
REDIS_URL=redis://127.0.0.1:6379/1
# Optional: tune the limits (defaults shown).
# THROTTLE_LOGIN=10/min
# THROTTLE_LOGIN_ACCOUNT=20/hour
# THROTTLE_REGISTER=5/min
# THROTTLE_PASSWORD_RESET=5/min

# --- PostgreSQL --------------------------------------------------------------
POSTGRES_DB=vivid_space
POSTGRES_USER=vivid
# Use a strong, unique password — NOT the dev one.
POSTGRES_PASSWORD=<STRONG_DB_PASSWORD>
POSTGRES_HOST=<DB_HOST>
POSTGRES_PORT=5432

# --- Media storage on S3 (AWS) -----------------------------------------------
# Leave AWS_STORAGE_BUCKET_NAME blank to keep local filesystem media (dev/VPS).
# Set it to route uploaded media (gallery images, etc.) to S3. Credentials come
# from the EC2 instance IAM role (preferred — no keys here); on non-AWS hosts,
# set AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY instead.
# AWS_STORAGE_BUCKET_NAME=vivid-media-prod
# AWS_S3_REGION_NAME=us-east-1
# Optional CloudFront domain in front of the bucket (else the raw S3 host is used):
# AWS_S3_CUSTOM_DOMAIN=dxxxxxxxxxxxx.cloudfront.net
# AWS_QUERYSTRING_AUTH=False   # public objects → clean, non-expiring URLs

# --- Frontend / links --------------------------------------------------------
# Origins allowed to call the API from the browser (CORS).
CORS_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com
# Public site origin used to build links inside emails (e.g. password reset).
FRONTEND_URL=https://your-domain.com

# --- Email (SMTP) ------------------------------------------------------------
# Delivery switches to real SMTP automatically once EMAIL_HOST_USER is set.
# ROTATE the Gmail app password that was committed to the dev .env before using it.
# For real volume, prefer a transactional provider (SendGrid / Mailgun / SES).
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=<SMTP_USERNAME>
EMAIL_HOST_PASSWORD=<SMTP_APP_PASSWORD_OR_API_KEY>
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=Vivid Space <no-reply@your-domain.com>
# Owner/admin notification recipient (Admin → Settings overrides this if set).
OWNER_EMAIL=<OWNER_INBOX@your-domain.com>
