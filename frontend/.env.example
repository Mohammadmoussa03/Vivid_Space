# Frontend build-time config. Copy to `.env` (or `.env.local`) — Vite only
# exposes variables prefixed with VITE_ to the bundle.

# API base. Defaults to /api, which the Vite dev proxy forwards to Django, so
# the whole app is served from one origin (ngrok-friendly). Only set this if the
# frontend is hosted somewhere that can't proxy.
# VITE_API_URL=/api

# Google sign-in. The OAuth 2.0 Web application client id from the Google Cloud
# console. Must be the SAME value as the backend's GOOGLE_OAUTH_CLIENT_ID — the
# backend checks the ID token's `aud` against it and rejects a mismatch.
# This value is public (it ships in the JS bundle); the client secret is not
# used by this flow and must never appear here.
# Leave blank/unset to hide the Google button entirely.
VITE_GOOGLE_CLIENT_ID=
