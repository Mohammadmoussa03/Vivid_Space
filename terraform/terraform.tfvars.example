########################################
# Copy to terraform.tfvars and fill in.
#   cp terraform.tfvars.example terraform.tfvars
########################################

aws_region  = "us-east-1"
environment = "prod"

# --- domain / DNS ---
# Leave domain_name = "" for a NO-DOMAIN HTTP TEST on the raw Elastic IP
# (test mode: DEBUG=True, HTTP only, no TLS/SES/Route53). Set a real domain for launch.
domain_name     = ""
manage_dns      = false        # true if your hosted zone lives in Route 53 (needs a domain)
route53_zone_id = ""           # required when manage_dns = true, e.g. "Z0123456ABCDEFG"
certbot_email   = ""           # your email (only used with a real domain)

# --- access ---
admin_cidr     = "203.0.113.10/32"   # YOUR public IP /32 — never 0.0.0.0/0
ssh_public_key = "ssh-ed25519 AAAA... you@host"   # contents of ~/.ssh/id_ed25519.pub

# --- app source (must be a repo the EC2 box can clone; public, or add a deploy key if private) ---
repo_url = "https://github.com/Mohammadmoussa03/Vivid_Space.git"

# --- sizes ---
instance_type     = "t3.small"
db_instance_class = "db.t4g.micro"

# --- S3 media (must be globally unique) ---
media_bucket_name = "vivid-media-prod"

# --- email / SES ---
manage_ses         = false
default_from_email = "Vivid Space <no-reply@example.com>"
# ses_smtp_username = ""   # from SES > SMTP settings (or fill .env on the box later)
# ses_smtp_password = ""
